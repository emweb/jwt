/** 

A {@link WFavicon} switching between two favicons. 
    
<p>

This is a {@link WFavicon} that uses a different {@link WFavicon} for its default and updated state.

<p>
@see WApplication#setFavicon(WFavicon icon)


    
*/
public class WFaviconPair extends WFavicon {
  private static Logger logger = LoggerFactory.getLogger(WFaviconPair.class);
  
  /**
  
  Constructs a {@link WFaviconPair}. 
          
  <p>
  
  Constructs a {@link WFaviconPair} from two {@link WFavicon}. 
          
  */
  public  WFaviconPair(WFavicon defaultFavicon, WFavicon updatedFavicon) {
  super ();
  this.defaultFavicon_ = defaultFavicon;
  this.updatedFavicon_ = updatedFavicon;
  }
  /**
  
  Sets the default favicon. 
          
  */
  public void setDefaultFavicon(WFavicon defaultFavicon) { 
    this.defaultFavicon_=  defaultFavicon;
}
  /**
  
  Returns the default favicon. 
          
  <p>
  
  @see WFaviconPair#setDefaultFavicon(WFavicon defaultFavicon)
  
  
          
  */
  public WFavicon  getDefaultFavicon() {
  return   this.defaultFavicon_;
  }
  /**
  
  Sets the updated favicon. 
          
  */
  public void setUpdatedFavicon(WFavicon updatedFavicon) { 
    this.updatedFavicon_=  updatedFavicon;
}
  /**
  
  Returns the updated favicon. 
          
  <p>
  
  @see WFaviconPair#setUpdatedFavicon(WFavicon updatedFavicon)
  
  
          
  */
  public WFavicon  getUpdatedFavicon() {
  return   this.updatedFavicon_;
  }
  /**
  
  Returns the current favicon used. 
          
  <p>
  
  @see WFaviconPair#setUpdatedFavicon(WFavicon updatedFavicon)
  @see WFaviconPair#setDefaultFavicon(WFavicon defaultFavicon)
  
  
          
  */
  public WFavicon  getCurrentFavicon() {
  return    this.isUpdated ()?  this.getUpdatedFavicon():  this.getDefaultFavicon();
  }
  public String getUrl() {
  if (  this.getCurrentFavicon() != null) {
    return   this.getCurrentFavicon().getUrl();
  }
  return "";
  }
  private WFavicon defaultFavicon_ ;
  private WFavicon updatedFavicon_ ;
}
