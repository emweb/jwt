/** 

A {@link WFavicon} located at a given URL. 
    
<p>

@see WApplication#setFavicon(WFavicon icon)


    
*/
public class WUrlFavicon extends WFavicon {
  private static Logger logger = LoggerFactory.getLogger(WUrlFavicon.class);
  
  /**
  
  Constructs a {@link WUrlFavicon}. 
          
  <p>
  
  Constructs a {@link WUrlFavicon} from the given <code>url</code>. 
          
  */
  public  WUrlFavicon(final String url) {
  super ();
  this.url_ = url;
  }
  /**
  
  Sets the URL. 
          
  */
  public void setUrl(final String url) { 
    this.url_=  url;
}
  public String getUrl() {
  return   this.url_;
  }
  private String url_ ;
}
